# ========================================
# 闲鱼自动化配置
# ========================================

# --- 认证信息 (必填) ---
# 从浏览器开发者工具获取的 Cookie
COOKIE=
# 用户 ID
USER_ID=
# 设备 ID (随机生成即可)
DEVICE_ID=
# 认证 Token
TOKEN=

# --- API 配置 ---
# x-sign 签名服务地址 (需要部署单独的签名服务)
XSIGN_SERVICE_URL=http://127.0.0.1:8080
# API 基础地址
API_BASE_URL=https://h5api.m.goofish.com
# WebSocket 地址
WS_URL=wss://wss-goofish.taobao.com/websocket

# --- 自动回复 ---
AUTO_REPLY_ENABLED=true
# 自动回复规则 (JSON 数组)
# 示例: [{"keywords":["在吗","你好"],"reply":"您好，请问有什么需要帮忙的吗？"},{"keywords":["包邮","运费"],"reply":"满50包邮哦~"}]
AUTO_REPLY_RULES=[]
# 默认回复 (没有匹配关键词时使用)
DEFAULT_REPLY=亲，稍等一下，我会尽快回复您~

# --- 自动擦亮 ---
AUTO_POLISH_ENABLED=true
# 擦亮间隔 (小时)
POLISH_INTERVAL_HOURS=8

# --- 价格监控 ---
PRICE_MONITOR_ENABLED=false
# 价格检查间隔 (分钟)
PRICE_CHECK_INTERVAL_MINUTES=30

# --- 自动上架 ---
AUTO_LIST_ENABLED=false

# --- 自动发货 ---
AUTO_DELIVER_ENABLED=false
# 发货规则 (JSON 数组)
# 示例: [{"itemId":"商品ID","keywords":["已付款","付款"],"deliverContent":"您的激活码是: XXXXX"}]
DELIVER_RULES=[]

# --- 数据抓取 ---
DATA_SCRAPE_ENABLED=false
# 抓取间隔 (小时)
SCRAPE_INTERVAL_HOURS=6

# --- 其他 ---
LOG_LEVEL=info
DATA_DIR=./data
